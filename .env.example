# PrivaCI environment variables (copy to .env — never commit .env)
#
# Required for a masking run:
SOURCE_DB_URL=postgresql://postgres:dev@localhost:55432/privaci_source
TARGET_DB_URL=postgresql://postgres:dev@localhost:55433/privaci_target

# Salt: minimum 32 characters. Generate with: privaci gen-salt
# ANONYMIZATION_SALT=file:///absolute/path/to/.privaci-salt
ANONYMIZATION_SALT=env://ANONYMIZATION_SALT

# Optional: keyed masking — distinct from ANONYMIZATION_SALT (license-gated)
# PSEUDONYM_KEY=file:///absolute/path/to/.pseudonym-key
# PSEUDONYM_KEY=env://PSEUDONYM_KEY
# PRIVACI_CONFIG=./tests/fixtures/configs/demo-corp.yaml

# Optional: logging (debug | info | warning | error)
PRIVACI_LOG_LEVEL=info

# Optional: secret URI examples (resolved at boot, never logged)
# SOURCE_DB_URL=aws-sm://my-secret-id?region=us-east-1&key=connection_string
# TARGET_DB_URL=azure-kv://my-vault/target-db-url
# ANONYMIZATION_SALT=vault://kv/data/privaci#salt
